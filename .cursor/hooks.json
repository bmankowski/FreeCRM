{
  "version": 1,
  "hooks": {
    "workspaceOpen": [
      {
        "command": ".cursor/hooks/start-log-watcher.sh"
      }
    ],
    "sessionStart": [
      {
        "command": ".cursor/hooks/start-log-watcher.sh"
      },
      {
        "command": ".cursor/hooks/session-log-fixer-context.sh"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/drain-log-warnings.sh",
        "loop_limit": null,
        "timeout": 30
      }
    ]
  }
}
