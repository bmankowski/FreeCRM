{
  "name": "freecrm-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for FreeCRM",
  "scripts": {
    "pw": "PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=ubuntu24.04-x64 node node_modules/@playwright/test/cli.js",
    "test": "npm run pw -- test --reporter=list",
    "test:e2e": "npm run pw -- test --reporter=./reporters/ai-feed-reporter.ts",
    "test:ui": "npm run pw -- test --ui",
    "test:debug": "npm run pw -- test --debug",
    "test:headed": "npm run pw -- test --headed",
    "install:browsers": "npm run pw -- install chromium",
    "codegen": "npm run pw -- codegen https://dev.itconnect.pl",
    "report": "npm run pw -- show-report",
    "crawl:modules": "tsx scripts/module-crawler.ts"
  },
  "keywords": [
    "e2e",
    "playwright",
    "crm",
    "testing"
  ],
  "author": "bmankowski@gmail.com",
  "license": "FreeCRM Public License 1.1",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.0.0"
  }
}
