# Production (10.0.0.220) — copy to /etc/freecrm/cv-import.conf
# Sole Cyberfolks consumer; REMOVE_SOURCE=1 deletes files from WWW after successful rsync.
SOURCE=cyberfolks
ENABLED=1
IMPORT_BASE=/var/www/import/cv
LOG_FILE=/var/log/cv-import.log
REMOVE_SOURCE=1
CYBERFOLKS_SSH_USER=itconnect
CYBERFOLKS_SSH_HOST=s63.cyber-folks.pl
CYBERFOLKS_SSH_PORT=222
CYBERFOLKS_REMOTE_PATH=/home/itconnect/public_html/wp-content/uploads/cv
RSYNC_CHOWN=www-yeti:www-yeti
RSYNC_CHMOD=Du=rwx,Dgo=rx,Fu=rw,Fog=r
AFTER_SYNC_CMD="su -c 'php /var/www/yetiforce/modules/Kandydaci/scripts/importNewCandidates.php' www-yeti"
