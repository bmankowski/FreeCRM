# FreeCRM PSR-4 Migration Configuration
# This file contains additional namespace mappings and migration rules

# Additional namespace mappings for specific classes
[NAMESPACE_MAPPINGS]
# Core classes
Vtiger_WebUI = "Vtiger\\Core\\"
Vtiger_EntryPoint = "Vtiger\\Core\\"
Vtiger_Session = "Vtiger\\Http\\"
Vtiger_Request = "Vtiger\\Http\\"
Vtiger_Response = "Vtiger\\Http\\"
Vtiger_Loader = "Vtiger\\Core\\"
Vtiger_Language_Handler = "Vtiger\\Language\\"
FreeCRM_Viewer = "Vtiger\\Runtime\\"
Vtiger_Theme = "Vtiger\\Runtime\\"
Vtiger_JavaScript = "Vtiger\\Runtime\\"
Vtiger_Controller = "Vtiger\\Runtime\\"
Vtiger_Base_Model = "Vtiger\\Core\\Models\\"
Vtiger_Record_Model = "Vtiger\\Core\\Models\\"
Vtiger_Module_Model = "Vtiger\\Core\\Models\\"
Vtiger_Field_Model = "Vtiger\\Core\\Models\\"

# Entity classes
CRMEntity = "Vtiger\\Core\\Entity\\"
Users = "Vtiger\\Modules\\Users\\"
Reports = "Vtiger\\Modules\\Reports\\"
Calendar = "Vtiger\\Modules\\Calendar\\"
Leads = "Vtiger\\Modules\\Leads\\"
Accounts = "Vtiger\\Modules\\Accounts\\"
Contacts = "Vtiger\\Modules\\Contacts\\"
HelpDesk = "Vtiger\\Modules\\HelpDesk\\"
Documents = "Vtiger\\Modules\\Documents\\"
Products = "Vtiger\\Modules\\Products\\"
Campaigns = "Vtiger\\Modules\\Campaigns\\"

# Settings classes
Settings_Companies_Record_Model = "Vtiger\\Modules\\Settings\\Companies\\Models\\"
Settings_Workflows_Record_Model = "Vtiger\\Modules\\Settings\\Workflows\\Models\\"
Settings_Users_Record_Model = "Vtiger\\Modules\\Settings\\Users\\Models\\"
Settings_Roles_Record_Model = "Vtiger\\Modules\\Settings\\Roles\\Models\\"

# OSS modules
OSSMailScanner_Record_Model = "Vtiger\\Modules\\OSSMailScanner\\Models\\"
OSSTimeControl_Record_Model = "Vtiger\\Modules\\OSSTimeControl\\Models\\"
OSSEmployees = "Vtiger\\Modules\\OSSEmployees\\"
OSSPasswords_Record_Model = "Vtiger\\Modules\\OSSPasswords\\Models\\"

# Other modules
PBXManager_Record_Model = "Vtiger\\Modules\\PBXManager\\Models\\"
SMSNotifier_Record_Model = "Vtiger\\Modules\\SMSNotifier\\Models\\"
ModComments_Record_Model = "Vtiger\\Modules\\ModComments\\Models\\"

# Utility classes
EmailTemplate = "Vtiger\\Utils\\"
LanguageTranslator = "Vtiger\\Language\\"
AppConfig = "Vtiger\\Config\\"
PearDatabase = "Vtiger\\Database\\"

# Field classes
DateTimeField = "Vtiger\\Fields\\"
CurrencyField = "Vtiger\\Fields\\"
DateTimeRange = "Vtiger\\Fields\\"

# Webservice classes
VtigerModuleOperation = "Vtiger\\Webservices\\"
WebserviceField = "Vtiger\\Webservices\\"
VtigerCRMObject = "Vtiger\\Webservices\\"
VtigerCRMActorMeta = "Vtiger\\Webservices\\"

# Migration rules
[MIGRATION_RULES]
# Files to skip during migration
SKIP_FILES = [
    "vendor/",
    "cache/",
    "storage/",
    "libraries/",
    "install/",
    "tests/"
]

# Classes to skip (keep as legacy)
SKIP_CLASSES = [
    "Yii",
    "Smarty",
    "PHPExcel"
]

# File patterns to handle specially
SPECIAL_PATTERNS = [
    "modules/*/models/*.php = Vtiger\\Modules\\{module}\\Models\\",
    "modules/*/views/*.php = Vtiger\\Modules\\{module}\\Views\\",
    "modules/*/actions/*.php = Vtiger\\Modules\\{module}\\Actions\\",
    "modules/*/uitypes/*.php = Vtiger\\Modules\\{module}\\UiTypes\\",
    "modules/*/dashboards/*.php = Vtiger\\Modules\\{module}\\Dashboards\\",
    "modules/*/textparsers/*.php = Vtiger\\Modules\\{module}\\TextParsers\\",
    "modules/*/handlers/*.php = Vtiger\\Modules\\{module}\\Handlers\\",
    "modules/*/helpers/*.php = Vtiger\\Modules\\{module}\\Helpers\\"
]

# Class name transformations
CLASS_TRANSFORMATIONS = [
    # Remove module prefix
    "{module}_Record_Model = Record",
    "{module}_Module_Model = Module",
    "{module}_Field_Model = Field",
    "{module}_ListView_Model = ListView",
    "{module}_DetailView_Model = DetailView",
    
    # Remove Vtiger prefix
    "Vtiger_{class} = {class}",
    
    # Handle special cases
    "Vtiger_Base_Model = BaseModel",
    "Vtiger_Record_Model = RecordModel",
    "Vtiger_Module_Model = ModuleModel",
    "Vtiger_Field_Model = FieldModel"
]

# Post-migration tasks
[POST_MIGRATION]
# Update composer.json autoload section
UPDATE_COMPOSER = true

# Create class aliases for backward compatibility
CREATE_ALIASES = true

# Update vimport() calls to use namespaces
UPDATE_VIMPORT = true

# Update require_once statements
UPDATE_REQUIRE = true
