#!/bin/bash

# class_to_filename - Renames PHP files to match their class names
# Usage: ./class_to_filename [directory] [--dry-run]
#
# This script scans PHP files, extracts the class name, and renames the file
# to match the class name (with .php extension)

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Default values
TARGET_DIR="${1:-.}"
DRY_RUN=false

# Check for --dry-run flag
if [[ "$*" == *"--dry-run"* ]]; then
    DRY_RUN=true
    echo -e "${YELLOW}DRY RUN MODE - No files will be renamed${NC}"
    echo ""
fi

# Validate target directory
if [[ ! -d "$TARGET_DIR" ]]; then
    echo -e "${RED}Error: Directory '$TARGET_DIR' does not exist${NC}"
    exit 1
fi

echo -e "${BLUE}Scanning for PHP files in: $TARGET_DIR${NC}"
echo ""

# Counter for statistics
TOTAL_FILES=0
RENAMED_FILES=0
SKIPPED_FILES=0
ERROR_FILES=0

# Function to extract class name from PHP file
extract_class_name() {
    local file="$1"
    
    # Try to extract class name (handles namespace and various formats)
    # Matches: class ClassName, abstract class ClassName, final class ClassName
    local class_name=$(grep -oP '^\s*(abstract\s+|final\s+)?class\s+\K[a-zA-Z_][a-zA-Z0-9_]*' "$file" | head -1)
    
    echo "$class_name"
}

# Function to rename file
rename_file() {
    local old_path="$1"
    local class_name="$2"
    
    local dir=$(dirname "$old_path")
    local old_filename=$(basename "$old_path")
    local new_filename="${class_name}.php"
    local new_path="${dir}/${new_filename}"
    
    # Skip if already correctly named
    if [[ "$old_filename" == "$new_filename" ]]; then
        echo -e "${GREEN}✓${NC} ${old_path} (already correct)"
        ((SKIPPED_FILES++))
        return 0
    fi
    
    # Check if target file already exists
    if [[ -f "$new_path" && "$old_path" != "$new_path" ]]; then
        echo -e "${RED}✗${NC} ${old_path}"
        echo -e "  ${RED}Error: Target file already exists: $new_path${NC}"
        ((ERROR_FILES++))
        return 1
    fi
    
    if [[ "$DRY_RUN" == true ]]; then
        echo -e "${YELLOW}→${NC} ${old_filename} → ${new_filename}"
        echo -e "  ${BLUE}Path: $dir${NC}"
        ((RENAMED_FILES++))
    else
        if mv "$old_path" "$new_path"; then
            echo -e "${GREEN}✓${NC} ${old_filename} → ${new_filename}"
            echo -e "  ${BLUE}Path: $dir${NC}"
            ((RENAMED_FILES++))
        else
            echo -e "${RED}✗${NC} Failed to rename: $old_path"
            ((ERROR_FILES++))
            return 1
        fi
    fi
    
    return 0
}

# Find all PHP files and process them
while IFS= read -r -d '' php_file; do
    ((TOTAL_FILES++))
    
    # Extract class name
    class_name=$(extract_class_name "$php_file")
    
    if [[ -z "$class_name" ]]; then
        echo -e "${YELLOW}⚠${NC} No class found in: $php_file"
        ((SKIPPED_FILES++))
        continue
    fi
    
    # Rename the file
    rename_file "$php_file" "$class_name"
    
done < <(find "$TARGET_DIR" -type f -name "*.php" -print0)

# Print summary
echo ""
echo -e "${BLUE}================================${NC}"
echo -e "${BLUE}Summary${NC}"
echo -e "${BLUE}================================${NC}"
echo -e "Total PHP files scanned: ${TOTAL_FILES}"
echo -e "${GREEN}Files renamed: ${RENAMED_FILES}${NC}"
echo -e "${YELLOW}Files skipped: ${SKIPPED_FILES}${NC}"
echo -e "${RED}Errors: ${ERROR_FILES}${NC}"

if [[ "$DRY_RUN" == true ]]; then
    echo ""
    echo -e "${YELLOW}This was a dry run. Run without --dry-run to apply changes.${NC}"
fi

exit 0
