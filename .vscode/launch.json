{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Listen for Xdebug",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "pathMappings": {
                "/home/bmankowski/projects/FreeYeti": "${workspaceFolder}"
            },
            "ignore": [
                "**/vendor/**/*.php"
            ],
            "log": true,
            "xdebugSettings": {
                "max_children": 128,
                "max_data": 1024,
                "max_depth": 5
            }
        },
        {
            "name": "Launch currently open script",
            "type": "php",
            "request": "launch",
            "program": "${file}",
            "cwd": "${fileDirname}",
            "port": 9003,
            "pathMappings": {
                "/home/bmankowski/projects/FreeYeti": "${workspaceFolder}"
            }
        },
        {
            "name": "Launch FreeYeti index.php",
            "type": "php",
            "request": "launch",
            "program": "${workspaceFolder}/index.php",
            "cwd": "${workspaceFolder}",
            "port": 9003,
            "pathMappings": {
                "/home/bmankowski/projects/FreeYeti": "${workspaceFolder}"
            },
            "args": []
        },
        {
            "name": "Launch debug test",
            "type": "php",
            "request": "launch",
            "program": "${workspaceFolder}/debug_test.php",
            "cwd": "${workspaceFolder}",
            "port": 9003,
            "pathMappings": {
                "/home/bmankowski/projects/FreeYeti": "${workspaceFolder}"
            }
        }
    ]
}
