# Copy to verama-job-sync.env and fill in credentials. Do not commit that file.

VERAMA_EMAIL=you@example.com
VERAMA_PASSWORD=change-me

# Optional overrides:
# VERAMA_BASE_URL=https://app.verama.com
# VERAMA_OUTPUT_DIR=/var/www/import/jobs
# VERAMA_REQUEST_DELAY_SEC=2
# VERAMA_LIST_PAGE_SIZE=100
# VERAMA_LOG_PATH=/var/www/html/cache/logs/verama-job-sync.log
