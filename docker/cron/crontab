# FreeCRM scheduler — runs all active vtiger_cron_task jobs (MINIMUM_CRON_FREQUENCY = 1 min).
# Per-task intervals are enforced inside CronRunner.
* * * * * flock -n /var/www/html/cache/cron.lock gosu www-data php /var/www/html/cron/vtigercron.php >> /var/www/html/cache/logs/cron.log 2>&1

# DEV ONLY: copy new CVs from prod backup (10.0.0.220) into import/cv/pending (FREECRM_DEV_CV_SYNC=1).
*/5 * * * * flock -n /var/www/html/cache/cv-sync.lock env FREECRM_DEV_CV_SYNC=1 HOME=/root /var/www/html/scripts/dev/sync-cv-from-prod.sh >> /var/www/html/cache/logs/cv-sync.log 2>&1
