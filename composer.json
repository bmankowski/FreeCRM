{
	"name": "freecrm/freecrm",
	"description": "An open and innovative CRM system.",
	"keywords": [
		"FreeCRM",
		"CRM",
		"open source crm",
		"best crm"
	],
	"license": "FreeCRM Public License 1.0",
	"homepage": "https://FreeCRM.com/",
	"type": "project",
	"support": {
		"issues": "https://github.com/FreeCRM/FreeCRM/issues",
		"wiki": "https://FreeCRM.com/en/documentation.html",
		"source": "https://github.com/FreeCRM/FreeCRM"
	},
	"authors": [
		{
			"name": "FreeCRM team",
			"email": "info@titantech.pl",
			"homepage": "https://FreeCRM.com/"
		}
	],
	"require": {
		"php": ">=5.6.0",
		"ext-imap": "*",
		"ext-openssl": "*",
		"ext-mbstring": "*",
		"ext-spl": "*",
		"ext-json": "*",
		"ext-dom": "*",
		"ext-zlib": "*",
		"ext-pdo": "*",
		"ext-curl": "*",
		"ext-gd": "*",
		"ext-pcre": "*",
		"ext-session": "*",
		"ext-soap": "*",
		"ext-zip": "*",
		"ext-xml": "*",
		"rmccue/requests": ">=1.7",
		"smarty/smarty": "^4",
		"phpmailer/phpmailer": ">=v5.2.22",
		"ezyang/htmlpurifier": ">=v4.8.0",
		"symfony/var-dumper": "^7.3",
		"simshaun/recurr": "^2.2",
		"linfo/linfo": "v3.0.1",
		"yiisoft/yii2": "~2.0.53",
		"antlr/antlr4-php-runtime": "^0.9.1",
		"monolog/monolog": "^3.9",
		"filp/whoops": "^2.18",
		"giggsey/libphonenumber-for-php": "^9.0"
	},
	"archive": {
		"exclude": [
			"tests"
		]
	},
	"config": {
		"autoloader-suffix": "YT",
		"allow-plugins": {
			"yiisoft/yii2-composer": true
		}
	},
	"autoload": {
		"psr-4": {
			"vtlib\\": "src/ModuleManagement/Adapters/",
			"App\\": "src/",
			"Exception\\": "src/Exceptions/",
			"DebugBar\\": "vendor/php-debugbar/php-debugbar/src/DebugBar/"
		},
		"files": [
			"src/Runtime/Globals.php",
			"src/Runtime/TemplateHelpers.php",
			"src/ModuleManagement/Adapters/Deprecated.php",
			"src/ModuleManagement/Adapters/StringTemplate.php",
			"src/Webservices/Utils.php"
		]
	},
	"repositories": {
		"asset-packagist": {
			"type": "composer",
			"url": "https://asset-packagist.org"
		}
	},
	"require-dev": {
		"rector/rector": ">2.1",
		"phpstan/phpstan": ">2.1",
		"php-debugbar/php-debugbar": ">=2.0"
	}
}
