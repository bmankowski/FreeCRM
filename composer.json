{
	"name": "FreeCRM/FreeCRM",
	"description": "An open and innovative CRM system.",
	"keywords": ["FreeCRM", "CRM", "open source crm", "best crm"],
	"license": "FreeCRM Public License 1.0",
	"homepage": "https://FreeCRM.com/",
	"type": "project",
	"support": {
		"issues": "https://github.com/FreeCRM/FreeCRM/issues",
		"wiki": "https://FreeCRM.com/en/documentation.html",
		"source": "https://github.com/FreeCRM/FreeCRM"
	},
	"authors": [
		{
			"name": "FreeCRM team",
			"email": "info@titantech.pl",
			"homepage": "https://FreeCRM.com/"
		}
	],
	"require": {
		"php": ">=5.6.0",
		"ext-imap": "*",
		"ext-openssl": "*",
		"ext-mbstring": "*",
		"ext-spl": "*",
		"ext-json": "*",
		"ext-dom": "*",
		"ext-zlib": "*",
		"ext-pdo": "*",
		"ext-curl": "*",
		"ext-gd": "*",
		"ext-pcre": "*",
		"ext-session": "*",
		"ext-soap": "*",
		"ext-zip": "*",
		"ext-xml": "*",
		"rmccue/requests": ">=1.7",
		"smarty/smarty": "^4",
		"phpmailer/phpmailer": ">=v5.2.22",
		"ezyang/htmlpurifier": ">=v4.8.0",
		"symfony/var-dumper": "^7.3",
		"simshaun/recurr": "^2.2",
		"linfo/linfo": "v3.0.1",
		"yiisoft/yii2": "~2.0.53",
		"antlr/antlr4-php-runtime": "^0.9.1",
		"monolog/monolog": "^3.9",
		"filp/whoops": "^2.18"

	},
	"archive": {
		"exclude": [
			"tests"
		]
	},
	 "config": {
        "autoloader-suffix": "YT",
		"allow-plugins": {
			"yiisoft/yii2-composer": true
		}
    },
	"autoload": {
		"psr-4": {
			"FreeCRM\\": "src/",
			"vtlib\\": "vtlib/Vtiger/",
			"includes\\": "include/",
			"App\\": "vendor/yetiforce/",
			"App\\Rector\\": "src/Rector/",
			"Api\\": "api/webservice/",
			"Exception\\": "include/exceptions/",
			"DebugBar\\": "vendor/php-debugbar/src/DebugBar/"
		},
		"files": [
			"include/runtime/Globals.php",
			"include/AppConfig.php",
			"include/LanguageTranslator.php",
			"include/http/Vtiger_Request.php",
			"include/http/Response.php",
			"include/http/Session.php",
			"include/runtime/BaseModel.php",
			"include/runtime/FreeCRM_Viewer.php",
			"include/runtime/JavaScript.php",
			"include/runtime/LanguageHandler.php",
			"include/runtime/Theme.php",
			"include/runtime/Layout.php",
			"include/runtime/Controller.php",
			"include/runtime/Cache.php",
			"include/utils/VTCacheUtils.php",
			"include/utils/utils.php",
			"vtlib/Vtiger/Deprecated.php"
		]
	},
	"repositories": {
		"asset-packagist": {
			"type": "composer",
			"url": "https://asset-packagist.org"
		}
	},
	"require-dev": {
		"rector/rector": "^2.1"
	}
}
